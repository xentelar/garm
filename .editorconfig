root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

# Matches multiple files with brace expansion notation
# Set default charset
[*.{erl,hrl,yaml,xml,json}]
charset = utf-8

# 2 space indentation
[*.erl]
indent_style = tab
indent_size = 2

# 2 space indentation
[*.hrl]
indent_style = tab
indent_size = 2

# Tab indentation (no size specified)
[Makefile]
indent_style = tab
